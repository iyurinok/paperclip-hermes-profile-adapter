{
  "name": "paperclip-hermes-profile-adapter",
  "version": "0.1.0",
  "private": true,
  "description": "Profile-aware Hermes adapter for Paperclip employee agents.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
